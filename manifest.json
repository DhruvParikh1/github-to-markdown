{
  "manifest_version": 3,
  "name": "GitHub to Markdown",
  "version": "1.3.1",
  "description": "Convert GitHub discussions, issues, and pull requests to clean, copyable markdown with one click",
  "permissions": [
    "activeTab",
    "scripting",
    "clipboardWrite",
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "https://github.com/*"
  ],
  "optional_host_permissions": [
    "https://*/*"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "GitHub to Markdown"
  },
  "commands": {
    "quick-copy-markdown": {
      "suggested_key": {
        "default": "Ctrl+Shift+M",
        "mac": "Command+Shift+M"
      },
      "description": "Quick copy current page as Markdown"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*"
      ],
      "js": [
        "parser.js",
        "content.js"
      ],
      "css": []
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "popup/popup.html",
        "popup/popup.css",
        "popup/popup.js",
        "icons/*"
      ],
      "matches": [
        "https://*/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
